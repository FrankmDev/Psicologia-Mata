{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.matacalapsicologia.es" }],
      "destination": "https://matacalapsicologia.es/:path*",
      "statusCode": 308
    },
    {
      "source": "/services",
      "destination": "https://matacalapsicologia.es/servicios/",
      "statusCode": 308
    },
    {
      "source": "/contact",
      "destination": "https://matacalapsicologia.es/contacto/",
      "statusCode": 308
    },
    {
      "source": "/servicios",
      "destination": "https://matacalapsicologia.es/servicios/",
      "statusCode": 308
    },
    {
      "source": "/blog",
      "destination": "https://matacalapsicologia.es/blog/",
      "statusCode": 308
    },
    {
      "source": "/contacto",
      "destination": "https://matacalapsicologia.es/contacto/",
      "statusCode": 308
    },
    {
      "source": "/privacidad",
      "destination": "https://matacalapsicologia.es/privacidad/",
      "statusCode": 308
    },
    {
      "source": "/aviso-legal",
      "destination": "https://matacalapsicologia.es/aviso-legal/",
      "statusCode": 308
    },
    {
      "source": "/cookies",
      "destination": "https://matacalapsicologia.es/cookies/",
      "statusCode": 308
    },
    {
      "source": "/blog/:slug",
      "destination": "https://matacalapsicologia.es/blog/:slug/",
      "statusCode": 308
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/(favicon\\.ico|favicon\\.avif|favicon-32x32\\.png|apple-touch-icon\\.png|icon-192x192\\.png|icon-512x512\\.png|site\\.webmanifest)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
