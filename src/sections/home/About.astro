---
import { Image } from 'astro:assets';
import mariaAngelesMata from "../../assets/maria-angeles-mata.jpeg";

const credentials = [
    {
        year: "2025",
        title: "Máster en Psicología General Sanitaria",
        institution: "Univ. Católica de Ávila",
    },
    {
        year: "2023",
        title: "Grado en Psicología – Mención en Psicología de la Salud",
        institution: "Univ. Católica de Ávila",
    },
    {
        year: "2021",
        title: "Máster en Neuropsicología",
        institution:
            "Escuela de Postgrado de Psicología y Psiquiatría. Reconocido por Univ. Católica de Cuyo (Argentina) y Univ. CLEA (México)",
    },
];
---

<section class="section bg-alabaster relative" id="sobre-mi">
    <div class="container-editorial">
        <!-- Introducción con tipografía gigante -->
        <div class="max-w-4xl mx-auto text-center mb-12 sm:mb-16 lg:mb-24">
            <div data-reveal>
                <span class="label-section text-[0.625rem] sm:text-xs"
                    >María Ángeles Mata</span
                >
            </div>
            <h2
                class="title-section mt-6 sm:mt-8"
                data-reveal
                data-reveal-delay="100"
            >
                "La terapia no es magia. Es un espacio donde puedes dejar de
                fingir que todo va bien, <em class="text-olive italic"
                    >y empezar a sentir que realmente lo está.</em
                >"
            </h2>
        </div>

        <div
            class="grid lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-16 items-stretch"
        >
            <!-- Imagen Editorial -->
            <div
                class="relative h-full"
                data-reveal="left"
                data-reveal-delay="200"
            >
                <div
                    class="relative w-full max-w-sm sm:max-w-md mx-auto h-full flex flex-col"
                >
                    <!-- Decoración de fondo -->
                    <div
                        class="absolute -inset-3 sm:-inset-4 bg-stone/20 rounded-[30px] sm:rounded-[40px] hidden sm:block rotate-[-3deg] z-0"
                    >
                    </div>

                    <div
                        class="img-reveal-wrapper flex-1 rounded-[20px] sm:rounded-[30px] overflow-hidden z-10 relative shadow-2xl shadow-ink/5"
                    >
                        <Image
                            src={mariaAngelesMata}
                            alt="María Ángeles Mata - Psicóloga"
                            class="w-full h-full object-cover filter grayscale-[20%] sepia-[15%] brightness-105 transition-all duration-1000 hover:grayscale-0 hover:scale-105"
                            style="min-height: 100%; aspect-ratio: 3/4;"
                            width={500}
                            height={666}
                            loading="lazy"
                        />
                    </div>

                    <!-- Sello flotante -->
                    <div
                        class="absolute -right-3 sm:-right-6 -bottom-3 sm:-bottom-6 w-24 sm:w-32 h-24 sm:h-32 bg-olive rounded-full flex items-center justify-center p-1.5 sm:p-2 z-20 shadow-xl hidden sm:flex animate-[spin_20s_linear_infinite]"
                    >
                        <svg
                            viewBox="0 0 100 100"
                            class="w-full h-full text-alabaster overflow-visible"
                        >
                            <path
                                id="textPath"
                                d="M 50, 50 m -35, 0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0"
                                fill="transparent"></path>
                            <text
                                font-family="Manrope"
                                font-size="11"
                                font-weight="600"
                                letter-spacing="2.5"
                                fill="currentColor"
                            >
                                <textPath href="#textPath" startOffset="0%">
                                    PSICOLOGÍA CLÍNICA • CÓRDOBA •
                                </textPath>
                            </text>
                        </svg>
                    </div>
                </div>
            </div>

            <!-- Contenido de texto -->
            <div
                class="flex flex-col justify-between"
                data-reveal="right"
                data-reveal-delay="300"
            >
                <div>
                    <div class="mb-6 sm:mb-8">
                        <span
                            class="text-label-xs text-olive text-[0.625rem] sm:text-xs"
                            >Sobre mí</span
                        >
                    </div>

                    <h3 class="title-section mb-6 sm:mb-8">
                        Un enfoque <em class="text-olive italic"
                            >clínico y humano</em
                        >
                    </h3>

                    <div class="space-y-4 sm:space-y-6 mb-8 sm:mb-12">
                        <p class="text-body-sm text-sm sm:text-base">
                            Llevo más de 15 años acompañando a personas que,
                            como tú, decidieron que merecían sentirse mejor. No
                            busco "arreglarte" — busco que descubras que ya
                            tienes dentro todo lo necesario.
                        </p>
                        <p class="text-body-sm text-sm sm:text-base">
                            Combino lo que dice la ciencia con lo que siente el
                            corazón. La terapia no es un manual: es una
                            conversación honesta donde tú pones tu historia y yo
                            pongo mi experiencia.
                        </p>
                    </div>

                    <!-- Trayectoria Académica -->
                    <div class="mb-8 sm:mb-12">
                        <div class="flex items-center gap-4 mb-4 sm:mb-6">
                            <span
                                class="text-label-xs text-charcoal text-[0.625rem] sm:text-xs"
                                >Formación</span
                            >
                            <span class="h-[1px] flex-1 bg-border-delicate"
                            ></span>
                        </div>

                        <div class="space-y-2 sm:space-y-3">
                            {
                                credentials.map((cred) => (
                                    <div class="flex items-baseline gap-3 sm:gap-4">
                                        <span class="text-label-xs text-olive w-8 sm:w-10 shrink-0 text-[0.625rem] sm:text-xs">
                                            {cred.year}
                                        </span>
                                        <span class="text-body-sm text-ink text-sm sm:text-base">
                                            {cred.title}
                                            <span class="text-charcoal">
                                                {" "}
                                                — {cred.institution}
                                            </span>
                                        </span>
                                    </div>
                                ))
                            }
                        </div>
                    </div>
                </div>

                <div>
                    <a
                        href="/contact"
                        class="btn btn-sage text-[0.6875rem] sm:text-xs py-3 px-5 sm:py-4 sm:px-8"
                    >
                        Descubre cómo puedo ayudarte
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
