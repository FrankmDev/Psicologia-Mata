---
/**
 * OptimizedImage - Componente de imagen optimizado para Astro
 * Usa el componente nativo <Image /> cuando es posible
 * Fallback a img con srcset para imágenes remotas (Unsplash)
 */
import { Image } from 'astro:assets';

type ImageQuality = 60 | 70 | 80 | 85 | 90 | 95 | 100;

interface Props {
  src: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: 'eager' | 'lazy';
  decoding?: 'async' | 'sync' | 'auto';
  class?: string;
  sizes?: string;
  quality?: ImageQuality;
  fit?: 'crop' | 'clip' | 'max' | 'scale' | 'fill';
  format?: 'auto' | 'webp' | 'jpeg' | 'jpg' | 'png' | 'avif' | 'jxl';
  priority?: boolean;
  caption?: string;
}

const {
  src,
  alt,
  width = 800,
  height,
  loading = 'lazy',
  decoding = 'async',
  class: className = '',
  sizes = '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 800px',
  quality = 80,
  fit = 'crop',
  format = 'auto',
  priority = false,
  caption
} = Astro.props;

// Detectar tipo de imagen
const isUnsplash = src.includes('images.unsplash.com');
const isRemote = src.startsWith('http://') || src.startsWith('https://');
const isLocalAsset = src.startsWith('/src/') || src.startsWith('~/');

// Calcular altura si no se proporciona (ratio 4:3 por defecto)
const calculatedHeight = height || Math.round(width * 0.75);

// Generar URL optimizada para Unsplash
function getOptimizedUnsplashUrl(url: string, w: number, q: number, f: string, fitMode: string): string {
  try {
    const urlObj = new URL(url);
    urlObj.searchParams.set('w', w.toString());
    urlObj.searchParams.set('q', q.toString());
    if (f !== 'auto') urlObj.searchParams.set('fm', f);
    if (fitMode !== 'crop') urlObj.searchParams.set('fit', fitMode);
    urlObj.searchParams.set('auto', 'format,compress');
    return urlObj.toString();
  } catch {
    return url;
  }
}

// Generar srcset para imágenes responsivas
function generateSrcset(originalUrl: string): string {
  if (!isUnsplash) return originalUrl;
  
  // Usar AVIF para mejor compresión, fallback a WebP
  const optimizedFormat = format === 'auto' ? 'avif' : format;
  const widths = [400, 600, 800, 1200];
  
  return widths
    .map(w => `${getOptimizedUnsplashUrl(originalUrl, w, quality, optimizedFormat, fit)} ${w}w`)
    .join(', ');
}

// URL optimizada
const optimizedSrc = isUnsplash 
  ? getOptimizedUnsplashUrl(src, width, quality, format, fit)
  : src;

const srcset = isUnsplash ? generateSrcset(src) : undefined;

// Determinar loading
const loadingAttr = priority ? 'eager' : loading;

// Determinar si debe tener fetchpriority
const fetchPriority = priority ? 'high' : undefined;
---

<figure class:list={['m-0', caption ? 'space-y-2' : '']">
  {isLocalAsset ? (
    <!-- Imagen local con optimización completa de Astro -->
    <Image
      src={src}
      alt={alt}
      width={width}
      height={calculatedHeight}
      quality={quality}
      format={format === 'auto' ? undefined : format}
      loading={loadingAttr}
      decoding={decoding}
      class={className}
      {...(priority && { fetchpriority: 'high' })}
    />
  ) : (
    <!-- Imagen remota con srcset optimizado -->
    <img
      src={optimizedSrc}
      alt={alt}
      width={width}
      height={calculatedHeight}
      loading={loadingAttr}
      decoding={decoding}
      class={className}
      {...(srcset && { srcset })}
      {...(isUnsplash && { sizes })}
      {...(fetchPriority && { fetchpriority: fetchPriority })}
      style={`aspect-ratio: ${width} / ${calculatedHeight};`}
    />
  )}
  {caption && (
    <figcaption class="text-sm text-charcoal text-center italic">
      {caption}
    </figcaption>
  )}
</figure>
