---
/**
 * RevealAnimation - Componente de animaciones de scroll
 * Usa IntersectionObserver eficiente con RAF para rendimiento óptimo
 * No requiere hidratación - el script se ejecuta en el cliente directamente
 */
---

<script>
  (function initRevealAnimations() {
    'use strict';
    
    // Configuración optimizada para rendimiento
    const CONFIG = {
      threshold: 0.1,
      rootMargin: '50px 0px 0px 0px', // Margen positivo para precargar antes de entrar en viewport
      once: true
    };
    
    let observer = null;
    let isInitialized = false;
    let rafId = null;
    
    // Throttle utility - mejor que debounce para scroll
    function throttle(fn, limit) {
      let inThrottle;
      return function(...args) {
        if (!inThrottle) {
          fn.apply(this, args);
          inThrottle = true;
          setTimeout(() => inThrottle = false, limit);
        }
      };
    }
    
    // Inicializar animaciones
    function init() {
      if (isInitialized || typeof window === 'undefined') return;
      
      const elements = document.querySelectorAll('[data-reveal], .img-reveal-wrapper');
      if (elements.length === 0) return;
      
      // Cancelar cualquier RAF pendiente
      if (rafId) {
        cancelAnimationFrame(rafId);
      }
      
      // Limpiar observer anterior si existe
      if (observer) {
        observer.disconnect();
      }
      
      // Crear nuevo observer con callback optimizado
      observer = new IntersectionObserver((entries) => {
        // Procesar todas las entradas en un solo batch
        const toReveal = [];
        
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delayStr = entry.target.getAttribute('data-reveal-delay');
            const delay = delayStr ? parseInt(delayStr, 10) : 0;
            toReveal.push({ target: entry.target, delay });
            
            if (CONFIG.once) {
              observer.unobserve(entry.target);
            }
          }
        });
        
        // Aplicar cambios en RAF para sincronizar con render
        if (toReveal.length > 0) {
          rafId = requestAnimationFrame(() => {
            toReveal.forEach(({ target, delay }) => {
              // Aplicar will-change justo antes de la animación
              target.style.willChange = 'opacity, transform';
              
              const applyVisible = () => {
                target.classList.add('is-visible');
                // Remover will-change después de la animación para liberar GPU
                setTimeout(() => {
                  target.style.willChange = 'auto';
                }, 1100); // Un poco más que la duración de la transición (1s)
              };
              
              if (delay === 0) {
                applyVisible();
              } else {
                setTimeout(applyVisible, delay);
              }
            });
          });
        }
      }, {
        threshold: CONFIG.threshold,
        rootMargin: CONFIG.rootMargin
      });
      
      // Observar elementos
      elements.forEach((el) => {
        el.classList.remove('is-visible');
        observer.observe(el);
      });
      
      isInitialized = true;
    }
    
    // Cleanup eficiente
    function cleanup() {
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = null;
      }
      if (observer) {
        observer.disconnect();
        observer = null;
      }
      isInitialized = false;
    }
    
    // Inicializar cuando el DOM esté listo
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      // Delay para no bloquear el LCP
      setTimeout(init, 0);
    }
    
    // Reinicializar en transiciones de página
    document.addEventListener('astro:page-load', () => {
      cleanup();
      requestAnimationFrame(init);
    });
    
    document.addEventListener('astro:before-swap', cleanup);
    
    // Throttled resize handler
    const throttledInit = throttle(() => {
      cleanup();
      init();
    }, 200);
    
    window.addEventListener('resize', throttledInit, { passive: true });
    
    // Cleanup en visibilitychange para ahorrar recursos
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cleanup();
      } else {
        init();
      }
    });
    
  })();
</script>
