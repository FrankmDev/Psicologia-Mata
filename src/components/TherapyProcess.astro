---
/**
 * TherapyProcess - Componente del proceso terapéutico reutilizable
 * Muestra los 4 pasos del proceso de terapia
 */

interface Step {
  number: string;
  title: string;
  subtitle: string;
  description: string;
}

interface Props {
  variant?: 'default' | 'dark';
  showCTA?: boolean;
  class?: string;
}

const { variant = 'default', showCTA = true, class: className = '' } = Astro.props;

const isDark = variant === 'dark';

const steps: Step[] = [
  {
    number: '01',
    title: 'Primera Sesión',
    subtitle: 'Conocernos',
    description: 'Cuéntame qué te trae aquí. No necesitas tener las palabras perfectas — solo la honestidad de empezar.'
  },
  {
    number: '02',
    title: 'Evaluación',
    subtitle: 'Entender',
    description: 'Juntos entendemos de dónde viene lo que sientes. No para señalar el pasado, sino para dibujar un camino diferente.'
  },
  {
    number: '03',
    title: 'Intervención',
    subtitle: 'Acompañar',
    description: 'Te doy herramientas que funcionan, para que puedas manejar lo que antes te desbordaba. Y practicamos hasta que te sientas seguro.'
  },
  {
    number: '04',
    title: 'Seguimiento',
    subtitle: 'Consolidar',
    description: 'Cuando estés listo, espaciamos las sesiones. Mi objetivo es que un día no me necesites — y que sepas que aquí estaré si me necesitas de nuevo.'
  }
];

const highlights = [
  { value: '50 min', label: 'Duración por sesión' },
  { value: 'Presencial', label: 'Consulta en Córdoba' },
  { value: 'Personalizado', label: 'Adaptado a ti' }
];
---

<section class:list={[
  'section relative overflow-hidden',
  isDark ? 'bg-charcoal text-alabaster' : 'bg-alabaster',
  className
]}>
  <!-- Fondo decorativo para dark -->
  {isDark && (
    <div class="absolute -top-1/2 -right-1/4 w-[80vw] h-[80vw] rounded-full bg-ink blur-[120px] opacity-50 pointer-events-none"></div>
  )}

  <div class="container-editorial relative z-10">
    
    <!-- Header -->
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 sm:gap-8 lg:gap-16 mb-12 sm:mb-16 lg:mb-20">
      <div data-reveal class="max-w-2xl">
        <div class="mb-6 sm:mb-8">
          <span class:list={['label-section text-[0.625rem] sm:text-xs', isDark && '!text-terracotta-light']}>El Proceso</span>
        </div>
        <h2 class:list={['title-section', isDark && '!text-alabaster']}>
          Cuatro pasos hacia tu <em class:list={['italic', isDark ? '!text-terracotta-light' : 'text-olive']}>bienestar</em>
        </h2>
      </div>

      <div class="flex flex-col items-start lg:items-end gap-4 sm:gap-6" data-reveal data-reveal-delay="100">
        <p class:list={[
          'text-body-sm max-w-sm lg:text-right text-sm sm:text-base',
          isDark ? 'text-taupe-light' : 'text-charcoal'
        ]}>
          No hay dos personas iguales, ni dos procesos iguales. Pero todos empiezan con una conversación.
        </p>
      </div>
    </div>

    <!-- Timeline -->
    <div class:list={['border-t', isDark ? 'border-border-strong/30' : 'border-border-delicate']}>
      {steps.map((step, index) => (
        <div
          class:list={[
            'group flex flex-col sm:flex-row items-start sm:items-center py-6 sm:py-8 lg:py-10 px-3 sm:px-4 -mx-3 sm:-mx-4 md:px-6 md:-mx-6 lg:px-8 lg:-mx-8 border-b transition-colors duration-500 rounded-lg',
            isDark 
              ? 'border-border-strong/30 hover:bg-ink/20' 
              : 'border-border-delicate hover:bg-cream/30'
          ]}
          data-reveal
          data-reveal-delay={index * 100}
        >
          {/* Columna número */}
          <div class="w-full sm:w-auto sm:min-w-[80px] lg:w-1/5 mb-2 sm:mb-0 sm:pr-4 lg:pr-8 flex items-center gap-3 sm:gap-4">
            <span class:list={[
              'text-label text-[0.625rem] sm:text-xs w-6 sm:w-8',
              isDark ? 'text-terracotta-light' : 'text-olive'
            ]}>
              {step.number}
            </span>
            <span class:list={[
              'flex-1 h-[1px] origin-left group-hover:scale-x-100 transition-transform duration-500 hidden sm:block',
              isDark ? 'bg-terracotta-light/30 group-hover:bg-terracotta-light' : 'bg-olive/30 group-hover:bg-olive'
            ]}></span>
          </div>

          {/* Columna título */}
          <div class="w-full sm:w-1/3 mb-2 sm:mb-0 sm:pr-4 lg:pr-8">
            <p class:list={[
              'text-label-xs uppercase tracking-[0.15em] mb-0.5 sm:mb-1 text-[0.625rem] sm:text-xs',
              isDark ? 'text-taupe-light' : 'text-charcoal'
            ]}>{step.subtitle}</p>
            <h3 class:list={[
              'font-serif text-lg sm:text-xl lg:text-2xl transition-colors duration-500',
              isDark 
                ? 'text-alabaster group-hover:text-terracotta-light' 
                : 'text-ink group-hover:text-olive'
            ]}>
              {step.title}
            </h3>
          </div>

          {/* Columna descripción */}
          <div class="w-full sm:w-5/12 mt-2 sm:mt-0">
            <p class:list={[
              'text-body-sm leading-relaxed text-sm sm:text-base',
              isDark ? 'text-taupe-light/80' : 'text-charcoal'
            ]}>
              {step.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    {/* Stats destacados */}
    <div class="mt-12 sm:mt-16 lg:mt-20" data-reveal data-reveal-delay="200">
      <div class="grid grid-cols-3 gap-4 sm:gap-8 lg:gap-0">
        {highlights.map((item, index) => (
          <div class:list={[
            'text-center',
            index < 2 && 'lg:border-r lg:border-border-strong/20'
          ]}>
            <span class:list={[
              'font-serif text-xl sm:text-2xl lg:text-3xl block mb-1',
              isDark ? 'text-terracotta-light' : 'text-olive'
            ]}>
              {item.value}
            </span>
            <span class:list={[
              'text-label-xs text-[0.625rem] sm:text-xs',
              isDark ? 'text-taupe-light/70' : 'text-charcoal'
            ]}>
              {item.label}
            </span>
          </div>
        ))}
      </div>
    </div>

    {/* CTA final */}
    {showCTA && (
      <div class:list={[
        'mt-12 sm:mt-16 pt-8 sm:pt-12 border-t',
        isDark ? 'border-border-strong/30' : 'border-border-delicate'
      ]} data-reveal data-reveal-delay="300">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 sm:gap-8">
          <div class="text-center md:text-left">
            <p class:list={['font-serif text-lg sm:text-xl mb-1', isDark ? 'text-alabaster' : 'text-ink']}>
              ¿Te gustaría que habláramos?
            </p>
            <p class:list={['text-body-sm text-sm sm:text-base', isDark ? 'text-taupe-light/70' : 'text-charcoal']}>
              La primera consulta es simplemente una conversación. Sin compromiso, sin presión.
            </p>
          </div>
          <div class="flex flex-col sm:flex-row gap-3 sm:gap-4">
            <a href="/contact" class="btn btn-primary group text-[0.6875rem] sm:text-xs py-3 px-5 sm:py-4 sm:px-8">
              <span>Pedir cita</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.75L21 12m0 0l-3.75 3.25M21 12H3" />
              </svg>
            </a>
            <a href="tel:+34661471971" class:list={[
              'btn !bg-transparent !border-border-strong/30 group text-[0.6875rem] sm:text-xs py-3 px-5 sm:py-4 sm:px-8',
              isDark ? '!text-alabaster hover:!bg-alabaster/10' : '!text-ink hover:!bg-ink hover:!text-alabaster'
            ]}>
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
              <span>Llamar</span>
            </a>
          </div>
        </div>
      </div>
    )}

  </div>
</section>
