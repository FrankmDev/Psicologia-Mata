---
/**
 * PageHeader - Encabezado de página reutilizable
 * Usado en páginas de servicios, contacto, blog, etc.
 */

interface Props {
  label: string;
  title: string;
  highlight?: string;
  description?: string;
  align?: 'left' | 'center';
  variant?: 'default' | 'dark';
  class?: string;
}

const {
  label,
  title,
  highlight,
  description,
  align = 'left',
  variant = 'default',
  class: className = ''
} = Astro.props;

const isDark = variant === 'dark';
const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const maxWidthClass = align === 'center' ? 'max-w-4xl mx-auto' : 'max-w-4xl';
---

<div class:list={[maxWidthClass, alignClass, className]} data-reveal>
  <span class:list={['label-section mb-8 block', isDark && '!text-terracotta-light']}>
    {label}
  </span>
  <h1 class:list={['title-section mb-8', isDark && '!text-alabaster']}>
    {title}
    {highlight && (
      <em class:list={['italic', isDark ? '!text-terracotta-light' : 'text-olive']}>
        {highlight}
      </em>
    )}
  </h1>
  {description && (
    <p class:list={['text-lead max-w-2xl', isDark ? '!text-taupe-light' : 'text-charcoal']}>
      {description}
    </p>
  )}
  <slot />
</div>
