---
// Schema.astro - JSON-LD Structured Data component
// Usage: <Schema type="localbusiness" data={businessData} />
// Supports: localbusiness, article, webpage, breadcrumbs, faqpage, professionalservice

interface GeoCoordinates {
  latitude: number;
  longitude: number;
}

interface LocalBusinessData {
  name: string;
  legalName?: string;
  description: string;
  url: string;
  telephone: string;
  email?: string;
  address: {
    streetAddress: string;
    addressLocality: string;
    postalCode: string;
    addressCountry: string;
  };
  geo?: GeoCoordinates;
  image?: string;
  priceRange?: string;
  openingHours?: string[];
  serviceArea?: string;
  specialties?: string[];
  services?: string[];
  socialProfiles?: string[];
  foundingDate?: string;
}

interface ArticleData {
  headline: string;
  description: string;
  image: string;
  datePublished: string;
  dateModified?: string;
  author: {
    name: string;
    url?: string;
  };
  publisher?: {
    name: string;
    logo: string;
  };
  url: string;
}

interface WebPageData {
  name: string;
  description: string;
  url: string;
  image?: string;
}

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface FAQItem {
  question: string;
  answer: string;
}

interface PersonData {
  name: string;
  url: string;
  jobTitle?: string;
  description?: string;
  telephone?: string;
  email?: string;
  image?: string;
  sameAs?: string[];
  address?: {
    streetAddress: string;
    addressLocality: string;
    postalCode: string;
    addressCountry: string;
  };
  knowsAbout?: string[];
  credentials?: {
    name: string;
    year?: string;
    institution?: string;
    type?: string;
  }[];
  licenseNumber?: string;
  licenseOrganization?: string;
}

interface Props {
  type: 'localbusiness' | 'article' | 'webpage' | 'breadcrumbs' | 'faqpage' | 'professionalservice' | 'person';
  data: LocalBusinessData | ArticleData | WebPageData | BreadcrumbItem[] | FAQItem[] | PersonData;
}

const { type, data } = Astro.props;

const siteUrl = 'https://www.matacalapsicologia.es';

function generateLocalBusinessSchema(data: LocalBusinessData) {
  const schema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': ['LocalBusiness', 'MedicalBusiness', 'ProfessionalService'],
    '@id': `${data.url}#business`,
    name: data.name,
    ...(data.legalName && { legalName: data.legalName }),
    description: data.description,
    url: data.url,
    telephone: data.telephone,
    email: data.email,
    address: {
      '@type': 'PostalAddress',
      ...data.address
    },
    image: data.image,
    priceRange: data.priceRange || '€€',
    openingHours: data.openingHours || ['Mo-Fr 09:00-20:00'],
    sameAs: data.socialProfiles || [],
    hasMap: `https://maps.google.com/?q=${encodeURIComponent(
      `${data.address.streetAddress}, ${data.address.postalCode} ${data.address.addressLocality}, ${data.address.addressCountry}`
    )}`,
    isAccessibleForFree: false,
    paymentAccepted: ['Cash', 'Credit Card', 'Bank Transfer'],
    currenciesAccepted: 'EUR',
    areaServed: data.serviceArea || 'Córdoba, España',
    ...(data.foundingDate && { foundingDate: data.foundingDate }),
    contactPoint: {
      '@type': 'ContactPoint',
      telephone: data.telephone,
      contactType: 'appointment booking',
      availableLanguage: ['es'],
      areaServed: 'ES'
    }
  };

  // Add geo coordinates if provided
  if (data.geo) {
    schema.geo = {
      '@type': 'GeoCoordinates',
      latitude: data.geo.latitude,
      longitude: data.geo.longitude
    };
  }

  // Add medical specialty for better healthcare SEO
  if (data.specialties) {
    schema.medicalSpecialty = data.specialties.map(specialty => ({
      '@type': 'MedicalSpecialty',
      name: specialty
    }));
  }

  // Add services if provided
  if (data.services) {
    schema.hasOfferCatalog = {
      '@type': 'OfferCatalog',
      name: 'Servicios de Psicología',
      itemListElement: data.services.map((service, index) => ({
        '@type': 'Offer',
        position: index + 1,
        itemOffered: {
          '@type': 'Service',
          name: service
        }
      }))
    };
  }

  return schema;
}

function generateArticleSchema(data: ArticleData) {
  const articleImage = data.image.startsWith('http') ? data.image : `${siteUrl}${data.image}`;

  return {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: data.headline,
    description: data.description,
    image: articleImage,
    datePublished: data.datePublished,
    dateModified: data.dateModified || data.datePublished,
    author: {
      '@type': 'Person',
      name: data.author.name,
      url: data.author.url
    },
    publisher: {
      '@type': 'Organization',
      name: data.publisher?.name || 'María Ángeles Mata',
      logo: {
        '@type': 'ImageObject',
        url: data.publisher?.logo || `${siteUrl}/favicon.avif`
      }
    },
    mainEntityOfPage: {
      '@type': 'WebPage',
      '@id': data.url
    }
  };
}

function generateWebPageSchema(data: WebPageData) {
  return {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: data.name,
    description: data.description,
    url: data.url,
    image: data.image
  };
}

function generateBreadcrumbSchema(items: BreadcrumbItem[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: items.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.name,
      item: item.url
    }))
  };
}

function generateFAQSchema(items: FAQItem[]) {
  return {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: items.map(item => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer
      }
    }))
  };
}

function generatePersonSchema(data: PersonData) {
  const schema: Record<string, unknown> = {
    '@context': 'https://schema.org',
    '@type': 'Person',
    '@id': `${data.url}#person`,
    name: data.name,
    url: data.url,
    jobTitle: data.jobTitle || 'Psicóloga General Sanitaria',
    description: data.description,
    telephone: data.telephone,
    email: data.email,
    image: data.image,
    sameAs: data.sameAs || [],
    worksFor: {
      '@type': 'MedicalBusiness',
      '@id': `${data.url}#business`
    }
  };

  if (data.address) {
    schema.address = {
      '@type': 'PostalAddress',
      ...data.address
    };
  }

  if (data.knowsAbout) {
    schema.knowsAbout = data.knowsAbout;
  }

  if (data.credentials && data.credentials.length > 0) {
    schema.hasCredential = data.credentials.map(cred => ({
      '@type': 'EducationalOccupationalCredential',
      name: cred.name,
      ...(cred.year && { dateCreated: cred.year }),
      ...(cred.type && { credentialCategory: cred.type }),
      ...(cred.institution && {
        recognizedBy: {
          '@type': cred.type === 'license' ? 'Organization' : 'CollegeOrUniversity',
          name: cred.institution
        }
      })
    }));
  }

  if (data.licenseNumber) {
    schema.identifier = {
      '@type': 'PropertyValue',
      name: 'Número de colegiada',
      value: data.licenseNumber,
      ...(data.licenseOrganization && {
        propertyID: data.licenseOrganization
      })
    };
  }

  return schema;
}

let schemaData: Record<string, unknown> | null = null;

switch (type) {
  case 'localbusiness':
    schemaData = generateLocalBusinessSchema(data as LocalBusinessData);
    break;
  case 'article':
    schemaData = generateArticleSchema(data as ArticleData);
    break;
  case 'webpage':
    schemaData = generateWebPageSchema(data as WebPageData);
    break;
  case 'breadcrumbs':
    schemaData = generateBreadcrumbSchema(data as BreadcrumbItem[]);
    break;
  case 'faqpage':
    schemaData = generateFAQSchema(data as FAQItem[]);
    break;
  case 'person':
    schemaData = generatePersonSchema(data as PersonData);
    break;
}

const schemaJson = schemaData ? JSON.stringify(schemaData) : '';
---

{schemaJson && (
  <script type="application/ld+json" set:html={schemaJson} />
)}
