---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Schema from '../components/Schema.astro';
import TherapyProcess from '../components/TherapyProcess.astro';
import CTASection from '../components/CTASection.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { mainServices } from '../data/services';
import { faqs } from '../data/faqs';
import { blogPostsList } from '../data/blog';

const title = "María Ángeles Mata — Psicóloga en Córdoba | Terapia Individual y de Pareja";
const description = "Psicóloga General Sanitaria en Córdoba con 15+ años de experiencia. Especialista en terapia individual, de pareja y familiar. Primera consulta sin compromiso.";

const previewPosts = blogPostsList.slice(0, 3);

const localBusinessData = {
  name: "María Ángeles Mata - Psicóloga Clínica",
  description: "Psicóloga General Sanitaria en Córdoba especializada en terapia individual, de pareja y familiar con más de 15 años de experiencia.",
  url: "https://psicologia-mata.es",
  telephone: "+34 661 471 971",
  email: "mangelesmatacala@hotmail.com",
  address: {
    streetAddress: "C/ Rodríguez Sánchez, 22",
    addressLocality: "Córdoba",
    postalCode: "14003",
    addressCountry: "ES"
  },
  image: "https://psicologia-mata.es/favicon.svg",
  priceRange: "€€",
  openingHours: ["Mo-Fr 09:00-20:00"]
};

const breadcrumbData = [
  { name: "Inicio", url: "https://psicologia-mata.es/" }
];

// Imágenes de servicios
const serviceImages = [
  'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=800&q=80',
  'https://images.unsplash.com/photo-1499209974431-9dddcece7f88?auto=format&fit=crop&w=800&q=80',
];

// Credenciales
const credentials = [
  { year: "2008", title: "Licenciatura en Psicología", institution: "Universidad de Granada" },
  { year: "2010", title: "Máster en Psicología Clínica", institution: "Universidad de Málaga" },
  { year: "2015", title: "Especialización Terapia de Pareja", institution: "EFT" },
  { year: "2024", title: "Formación Continua", institution: "Terapias de Tercera Generación" },
];

// Valores
const values = [
  {
    title: "Confidencialidad Absoluta",
    description: "Lo que cuentes aquí, se queda aquí. Tu historia es solo tuya, y mi deber sagrado es protegerla.",
    icon: "M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z"
  },
  {
    title: "Empatía Real",
    description: "Hay cosas que no se dicen con palabras. Yo las escucho igual. Sin juzgarte, sin prisas, con la paciencia que necesitas.",
    icon: "M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"
  },
  {
    title: "Rigor Clínico",
    description: "No improviso. Uso técnicas que la ciencia ha probado, aplicadas con el corazón puesto en cada sesión.",
    icon: "M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.315 48.315 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"
  },
  {
    title: "Compromiso Genuino",
    description: "Cuando tú das el paso de venir, yo doy el mío de estar completamente presente. Tu proceso es mi prioridad.",
    icon: "M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"
  }
];
---

<Layout 
  {title}
  {description}
  type="website"
>
  <Schema slot="schema" type="localbusiness" data={localBusinessData} />
  <Schema slot="schema" type="breadcrumbs" data={breadcrumbData} />
  <Schema slot="schema" type="webpage" data={{ name: title, description, url: "https://psicologia-mata.es/" }} />
  
  <Header activePage="Inicio" />
  
  <main id="main-content" role="main">
    
    <!-- Hero -->
    <section class="min-h-screen flex items-center bg-alabaster relative overflow-hidden pt-4" aria-label="Introducción">
      <div class="bg-aurora"></div>

      <div class="container-editorial relative z-10 pt-6 pb-16 lg:pt-8">
        <div class="grid lg:grid-cols-12 gap-x-12 gap-y-16 items-center">

          <!-- Contenido principal -->
          <div class="lg:col-span-7 z-20 flex flex-col justify-center relative">
            <div class="absolute -left-12 lg:-left-24 top-0 w-[1px] h-full bg-border-delicate hidden md:block"></div>

            <div class="mb-10" data-reveal>
              <span class="label-section">Psicología Clínica en Córdoba</span>
            </div>

            <h1 class="font-serif text-[clamp(3.5rem,7vw,5rem)] lg:text-[5.5rem] font-light text-ink leading-[0.95] mb-10 tracking-tight">
              <div data-reveal data-reveal-delay="100">Encuentra</div>
              <div data-reveal data-reveal-delay="200" class="flex items-center gap-4 lg:gap-8 mt-2">
                <span class="h-[1px] w-12 lg:w-24 bg-ink opacity-30"></span>
                <em class="font-light text-olive">tu equilibrio</em>
              </div>
              <div data-reveal data-reveal-delay="300" class="mt-2">interior.</div>
            </h1>

            <div class="max-w-xl pl-0 md:pl-8 border-l border-transparent md:border-border-strong mb-12">
              <p class="text-lead" data-reveal data-reveal-delay="400">
                Cuando todo pesa demasiado, no tienes que atravesarlo solo. Soy María Ángeles Mata, y estoy aquí para acompañarte en ese primer paso hacia sentirte mejor.
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-8" data-reveal data-reveal-delay="500">
              <a href="/contact" class="btn btn-sage group">
                <span>Quiero hablar contigo</span>
              </a>

              <div class="flex flex-col gap-2">
                <div class="flex items-center gap-3">
                  <span class="w-1 h-1 rounded-full bg-olive"></span>
                  <span class="text-label-xs text-charcoal">Terapia Individual</span>
                </div>
                <div class="flex items-center gap-3">
                  <span class="w-1 h-1 rounded-full bg-olive"></span>
                  <span class="text-label-xs text-charcoal">Terapia de Pareja</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Imagen Hero -->
          <div class="lg:col-span-5 relative mt-12 lg:mt-0">
            <div class="absolute -right-8 top-1/2 -translate-y-1/2 rotate-180 [writing-mode:vertical-rl] text-label-xs text-ink opacity-40 z-30 hidden xl:block" data-reveal="right" data-reveal-delay="700">
              Córdoba, España — Consulta Presencial
            </div>

            <div class="relative w-full max-w-[420px] mx-auto lg:ml-auto lg:mr-0" data-reveal="right" data-reveal-delay="300">
              <div class="absolute -inset-y-8 -inset-x-4 bg-stone/20 rounded-t-full hidden md:block backdrop-blur-sm z-0"></div>

              <div class="img-reveal-wrapper rounded-t-full rounded-b-[100px] overflow-hidden aspect-[3/4] z-10 relative shadow-2xl shadow-ink/5 group">
                <OptimizedImage
                  src="https://images.unsplash.com/photo-1573497620053-ea5300f94f21?auto=format&fit=crop&w=800&q=85"
                  alt="María Ángeles Mata - Psicóloga Clínica"
                  width={600}
                  height={800}
                  loading="eager"
                  priority={true}
                  class="w-full h-full object-cover scale-105 transition-all duration-[1.5s] group-hover:scale-100 group-hover:opacity-100 mix-blend-multiply opacity-90"
                />
                <div class="absolute inset-0 bg-olive/10 mix-blend-color pointer-events-none group-hover:bg-olive/5 transition-colors duration-500"></div>
              </div>

              <div class="absolute -bottom-10 -left-4 md:-left-12 bg-alabaster p-6 lg:p-8 border border-border-delicate z-20 shadow-xl shadow-ink/5 flex items-center gap-6 hover:border-olive/30 hover:shadow-2xl hover:shadow-ink/10 transition-all duration-500" data-reveal data-reveal-delay="600">
                <div>
                  <p class="font-serif text-4xl lg:text-5xl text-ink leading-none mb-1">15+</p>
                </div>
                <div class="h-10 w-[1px] bg-border-strong"></div>
                <div>
                  <p class="text-label-sm text-charcoal leading-relaxed">
                    Años acompañando<br />a personas como tú
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Servicios -->
    <section class="section bg-cream relative" id="servicios">
      <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(var(--color-ink) 1px, transparent 1px); background-size: 32px 32px;"></div>

      <div class="container-editorial relative z-10">
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-12 mb-20 lg:mb-32">
          <div data-reveal class="max-w-2xl">
            <div class="mb-8">
              <span class="label-section">Áreas de Especialidad</span>
            </div>
            <h2 class="title-section">
              Un enfoque <em>clínico y humano</em> para tu bienestar.
            </h2>
          </div>
          
          <div class="flex flex-col items-start lg:items-end gap-6" data-reveal data-reveal-delay="200">
            <p class="text-body-sm max-w-sm lg:text-right">
              Tratamientos basados en evidencia, adaptados a tu historia personal y momento vital.
            </p>
            <a href="/services" class="btn btn-outline">Ver todos los servicios</a>
          </div>
        </div>

        <div class="grid lg:grid-cols-12 gap-y-24 gap-x-10">
          {mainServices.map((service, index) => (
            <a
              href="/services"
              class={`group block lg:col-span-4 ${index === 1 ? 'lg:mt-32' : index === 2 ? 'lg:mt-16' : ''}`}
              data-reveal
              data-reveal-delay={index * 200}
            >
              <article class="relative h-full flex flex-col">
                <span class="absolute -top-8 -left-4 font-serif text-[8rem] leading-none text-olive/[0.03] font-light select-none pointer-events-none transition-all duration-700 group-hover:text-olive/[0.06] group-hover:-translate-y-2">
                  0{index + 1}
                </span>
                
                <div class="relative mb-8 img-reveal-wrapper aspect-[4/5] overflow-hidden bg-cream">
                  <OptimizedImage
                    src={serviceImages[index]}
                    alt={service.title}
                    width={400}
                    height={500}
                    loading={index === 0 ? "eager" : "lazy"}
                    class="w-full h-full object-cover filter grayscale-[30%] sepia-[10%] group-hover:grayscale-0 group-hover:sepia-0 group-hover:scale-105 transition-all duration-1000 ease-out"
                  />
                  <div class="absolute inset-0 bg-ink/5 group-hover:bg-transparent transition-colors duration-700"></div>
                  <div class="absolute top-0 left-0 w-16 h-16 border-t-2 border-l-2 border-olive/0 group-hover:border-olive/30 transition-all duration-500"></div>
                  <div class="absolute bottom-0 right-0 w-16 h-16 border-b-2 border-r-2 border-olive/0 group-hover:border-olive/30 transition-all duration-500"></div>
                </div>

                <div class="relative flex-1 flex flex-col pl-0">
                  <div class="flex items-baseline gap-4 mb-4">
                    <span class="text-label text-olive">0{index + 1}</span>
                    <span class="flex-1 h-[1px] bg-border-delicate group-hover:bg-olive/30 transition-colors duration-500 origin-left group-hover:scale-x-100"></span>
                  </div>
                  
                  <h3 class="font-serif text-2xl lg:text-[1.75rem] text-ink group-hover:text-olive transition-colors duration-500 leading-[1.15] mb-5">
                    {service.title}
                  </h3>
                  
                  <p class="text-body-sm text-charcoal leading-relaxed mb-8 flex-1">
                    {service.shortDescription}
                  </p>
                  
                  <div class="flex items-center justify-between pt-6 border-t border-border-delicate group-hover:border-olive/20 transition-colors duration-500">
                    <span class="text-label-sm text-ink">{service.duration}</span>
                    
                    <span class="flex items-center gap-3 text-ink group-hover:text-olive transition-colors duration-500">
                      <span class="text-label-xs">Ver servicio</span>
                      <span class="w-8 h-8 rounded-full border border-border-strong flex items-center justify-center group-hover:bg-ink group-hover:border-ink group-hover:text-alabaster group-hover:scale-110 transition-all duration-500">
                        <svg class="w-3 h-3 transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
                        </svg>
                      </span>
                    </span>
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Sobre Mí -->
    <section class="section bg-alabaster relative" id="sobre-mi">
      <div class="container-editorial">
        <div class="max-w-4xl mx-auto text-center mb-20 lg:mb-32">
          <div data-reveal>
            <span class="label-section">María Ángeles Mata</span>
          </div>
          <h2 class="title-section mt-8" data-reveal data-reveal-delay="100">
            "La terapia no es magia. Es un espacio donde puedes dejar de fingir que todo va bien, <em class="text-olive italic">y empezar a sentir que realmente lo está.</em>"
          </h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-stretch">
          <div class="relative h-full" data-reveal="left" data-reveal-delay="200">
            <div class="relative w-full max-w-md mx-auto h-full flex flex-col">
              <div class="absolute -inset-4 bg-stone/20 rounded-[40px] hidden md:block rotate-[-3deg] z-0"></div>

              <div class="img-reveal-wrapper flex-1 rounded-[30px] overflow-hidden z-10 relative shadow-2xl shadow-ink/5 min-h-[500px]">
                <OptimizedImage
                  src="https://images.unsplash.com/photo-1551836022-d5d88e9218df?auto=format&fit=crop&w=800&q=85"
                  alt="María Ángeles Mata - Psicóloga"
                  width={500}
                  height={666}
                  loading="lazy"
                  class="w-full h-full object-cover filter grayscale-[20%] sepia-[15%] brightness-105 transition-all duration-1000 hover:grayscale-0 hover:scale-105"
                />
              </div>

              <div class="absolute -right-6 -bottom-6 w-32 h-32 bg-olive rounded-full flex items-center justify-center p-2 z-20 shadow-xl hidden md:flex animate-[spin_20s_linear_infinite]">
                <svg viewBox="0 0 100 100" class="w-full h-full text-alabaster overflow-visible">
                  <path id="textPath" d="M 50, 50 m -35, 0 a 35,35 0 1,1 70,0 a 35,35 0 1,1 -70,0" fill="transparent" />
                  <text font-family="Manrope" font-size="11" font-weight="600" letter-spacing="2.5" fill="currentColor">
                    <textPath href="#textPath" startOffset="0%">
                      PSICOLOGÍA CLÍNICA • CÓRDOBA •
                    </textPath>
                  </text>
                </svg>
              </div>
            </div>
          </div>

          <div class="flex flex-col justify-between" data-reveal="right" data-reveal-delay="300">
            <div>
              <div class="mb-8">
                <span class="text-label-sm text-olive">Sobre mí</span>
              </div>

              <h3 class="title-section mb-8">
                Un enfoque <em class="text-olive italic">clínico y humano</em>
              </h3>

              <div class="space-y-6 mb-12">
                <p class="text-body-sm">
                  Llevo más de 15 años acompañando a personas que, como tú, decidieron que merecían sentirse mejor. No busco "arreglarte" — busco que descubras que ya tienes dentro todo lo necesario.
                </p>
                <p class="text-body-sm">
                  Combino lo que dice la ciencia con lo que siente el corazón. La terapia no es un manual: es una conversación honesta donde tú pones tu historia y yo pongo mi experiencia.
                </p>
              </div>

              <div class="mb-12">
                <div class="flex items-center gap-4 mb-6">
                  <span class="text-label-sm text-charcoal">Formación</span>
                  <span class="h-[1px] flex-1 bg-border-delicate"></span>
                </div>

                <div class="space-y-3">
                  {credentials.map((cred) => (
                    <div class="flex items-baseline gap-4">
                      <span class="text-label-xs text-olive w-10 shrink-0">{cred.year}</span>
                      <span class="text-body-sm text-ink">
                        {cred.title}
                        <span class="text-charcoal"> — {cred.institution}</span>
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div>
              <a href="/contact" class="btn btn-sage">Descubre cómo puedo ayudarte</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Proceso -->
    <TherapyProcess variant="dark" showCTA={true} />

    <!-- Valores -->
    <section class="section bg-alabaster relative" id="valores">
      <div class="container-editorial">
        <div class="max-w-4xl mx-auto text-center mb-20 lg:mb-32">
          <div data-reveal>
            <span class="label-section mb-10">Mis Pilares</span>
          </div>
          <h2 class="title-section" data-reveal data-reveal-delay="100">
            La base de una terapia <em class="text-olive italic">segura y eficaz</em>
          </h2>
          <p class="text-lead mt-10 max-w-2xl mx-auto" data-reveal data-reveal-delay="200">
            Estos cuatro principios guían cada sesión. No son solo palabras: son mi compromiso contigo desde el primer día.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 lg:gap-16">
          {values.map((value, index) => (
            <div class="relative p-10 lg:p-14 border border-border-delicate bg-cream/30 hover:bg-cream hover:border-olive/30 transition-all duration-700 group" data-reveal data-reveal-delay={index * 150}>
              <span class="absolute top-6 right-8 font-serif text-[6rem] leading-none text-olive/5 font-light select-none group-hover:text-olive/10 transition-colors duration-700">
                0{index + 1}
              </span>

              <div class="relative z-10 flex flex-col h-full">
                <div class="w-12 h-12 rounded-full border border-border-strong flex items-center justify-center text-ink mb-8 group-hover:bg-olive group-hover:text-alabaster group-hover:border-olive transition-all duration-500">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                    <path stroke-linecap="round" stroke-linejoin="round" d={value.icon} />
                  </svg>
                </div>

                <h3 class="text-title text-ink mb-4">{value.title}</h3>
                <p class="text-body-sm flex-1">{value.description}</p>
                <div class="w-0 h-[1px] bg-olive mt-10 group-hover:w-full transition-all duration-1000 ease-out"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Blog Preview -->
    <section class="section bg-cream relative" id="blog">
      <div class="container-editorial">
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-8 lg:gap-16 mb-16 lg:mb-24">
          <div data-reveal class="max-w-2xl">
            <div class="mb-8">
              <span class="label-section">Recursos</span>
            </div>
            <h2 class="title-section">
              Aprender para <em class="text-olive italic">sentirte mejor</em>
            </h2>
          </div>

          <div data-reveal data-reveal-delay="100">
            <a href="/blog" class="btn btn-outline">Ver todos los artículos</a>
          </div>
        </div>

        <div class="border-t border-border-strong/30">
          {previewPosts.map((post, index) => (
            <article class="group border-b border-border-strong/30 hover:bg-cream/50 transition-colors duration-500" data-reveal data-reveal-delay={index * 100}>
              <a href={`/blog/${post.slug}`} class="block py-10 lg:py-12">
                <div class="flex flex-col lg:flex-row lg:items-center gap-4 lg:gap-12">
                  <div class="w-full lg:w-24 shrink-0 flex items-center gap-4 lg:gap-0">
                    <span class="text-label text-olive w-8">0{index + 1}</span>
                    <span class="lg:hidden text-label-xs text-charcoal uppercase tracking-wider">{post.category}</span>
                  </div>

                  <div class="flex-1 min-w-0">
                    <div class="hidden lg:flex items-center gap-4 mb-3">
                      <span class="text-label-xs text-charcoal uppercase tracking-[0.15em]">{post.category}</span>
                      <span class="w-8 h-[1px] bg-border-delicate"></span>
                      <span class="text-label-xs text-charcoal/70">{post.date}</span>
                    </div>

                    <h3 class="font-serif text-xl lg:text-2xl text-ink group-hover:text-olive transition-colors duration-500 leading-tight mb-3">
                      {post.title}
                    </h3>

                    <p class="text-body-sm text-charcoal line-clamp-2 max-w-2xl">
                      {post.excerpt}
                    </p>
                  </div>

                  <div class="lg:hidden">
                    <span class="text-label-xs text-charcoal/70">{post.date}</span>
                  </div>

                  <div class="hidden lg:flex shrink-0 w-12 h-12 rounded-full border border-border-strong items-center justify-center text-ink group-hover:bg-ink group-hover:border-ink group-hover:text-alabaster group-hover:scale-110 transition-all duration-500">
                    <svg class="w-4 h-4 transform group-hover:translate-x-0.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.75L21 12m0 0l-3.75 3.25M21 12H3" />
                    </svg>
                  </div>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section class="relative overflow-hidden bg-ink" id="contacto-cta">
      <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-r from-ink via-ink/85 to-ink/60 z-10"></div>
        <OptimizedImage
          src="https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=1600&q=80"
          alt=""
          width={1600}
          height={800}
          loading="lazy"
          class="w-full h-full object-cover mix-blend-luminosity opacity-30"
        />
      </div>

      <div class="container-editorial relative z-20">
        <div class="py-24 lg:py-32">
          <div class="max-w-3xl">
            <div class="mb-10" data-reveal>
              <span class="inline-flex items-center gap-4">
                <span class="w-8 h-[1px] bg-terracotta-light"></span>
                <span class="text-label-sm text-terracotta-light">¿Hablamos?</span>
              </span>
            </div>

            <h2 class="font-serif text-4xl lg:text-5xl xl:text-6xl leading-[1.1] text-alabaster mb-8" data-reveal data-reveal-delay="100">
              El primer paso es solo <em class="italic text-terracotta-light">una conversación</em>
            </h2>

            <p class="text-body !text-alabaster/80 mb-12 max-w-xl leading-relaxed" data-reveal data-reveal-delay="200">
              No tienes que tenerlo todo claro para empezar. Solo necesitas sentir que ya no quieres seguir así. El resto lo hacemos juntos.
            </p>

            <div class="flex flex-col sm:flex-row items-start gap-4 mb-16" data-reveal data-reveal-delay="300">
              <a href="/contact" class="btn btn-primary !bg-terracotta-light !text-ink hover:!bg-alabaster group">
                <span>Me gustaría hablar contigo</span>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.75L21 12m0 0l-3.75 3.25M21 12H3" />
                </svg>
              </a>
              <a href="tel:+34661471971" class="btn !bg-transparent !border-border-strong/30 !text-alabaster hover:!bg-alabaster/10">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
                </svg>
                <span>661 471 971</span>
              </a>
            </div>

            <div class="pt-8 border-t border-border-strong/20 flex flex-col md:flex-row justify-between items-start md:items-center gap-6" data-reveal data-reveal-delay="400">
              <div class="flex flex-wrap gap-x-10 gap-y-4">
                {["Respuesta en 24h", "Primera consulta sin compromiso", "Consulta en Córdoba"].map((item) => (
                  <div class="flex items-center gap-3">
                    <span class="w-1.5 h-1.5 rounded-full bg-terracotta-light"></span>
                    <span class="text-label-xs !text-alabaster/70">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="section bg-cream relative" id="faqs">
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,')] opacity-[0.15] mix-blend-multiply pointer-events-none"></div>

      <div class="container-editorial relative z-10">
        <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-12 mb-20 lg:mb-32">
          <div data-reveal class="max-w-2xl">
            <div class="mb-8">
              <span class="label-section">Dudas Frecuentes</span>
            </div>
            <h2 class="title-section">
              Claridad antes de <em class="text-olive italic">empezar</em>
            </h2>
          </div>
          <div class="flex items-end lg:justify-end" data-reveal data-reveal-delay="100">
            <p class="text-body-sm max-w-sm lg:text-right border-l-2 lg:border-l-0 lg:border-r-2 border-olive pl-6 lg:pl-0 lg:pr-6">
              Resolver tus dudas iniciales es parte del proceso de construir la confianza necesaria para la terapia.
            </p>
          </div>
        </div>

        <div class="max-w-4xl mx-auto border-t border-ink/20">
          {faqs.map((faq, index) => (
            <div data-reveal data-reveal-delay={index * 100}>
              <details class="group border-b border-ink/20 open:border-olive/50 transition-colors duration-500">
                <summary class="flex cursor-pointer items-center justify-between gap-8 py-8 lg:py-10 select-none list-none">
                  <div class="flex items-center gap-6 md:gap-12 min-w-0 flex-1">
                    <span class="text-label text-olive font-semibold w-8 md:w-12 shrink-0">0{index + 1}</span>
                    <h3 class="font-serif text-xl lg:text-2xl text-ink group-hover:text-olive transition-colors duration-300 pr-4 leading-[1.2]">
                      {faq.question}
                    </h3>
                  </div>
                  
                  <div class="shrink-0 w-10 h-10 rounded-full border border-ink/20 flex items-center justify-center group-hover:bg-ink group-hover:border-ink text-ink group-hover:text-alabaster transition-all duration-500 group-open:rotate-[135deg]">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                  </div>
                </summary>
                
                <div class="pb-10 pl-[4.5rem] md:pl-24 text-body text-charcoal max-w-3xl">
                  {faq.answer}
                </div>
              </details>
            </div>
          ))}
        </div>

        <div class="mt-24 pt-12 border-t border-border-delicate flex flex-col md:flex-row items-center justify-between gap-8 text-center md:text-left" data-reveal data-reveal-delay="300">
          <div>
            <p class="text-label-sm text-charcoal mb-2">¿No encuentras lo que buscas?</p>
            <p class="text-title-sm text-ink">Escríbeme directamente</p>
          </div>
          <a href="/contact" class="btn btn-outline">Contactar ahora</a>
        </div>
      </div>
    </section>

  </main>
  
  <Footer />
</Layout>
