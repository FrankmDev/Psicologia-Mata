---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/PageHeader.astro';
import ContactInfoCard from '../components/ContactInfoCard.astro';
import CTASection from '../components/CTASection.astro';
import Schema from '../components/Schema.astro';
import Icon from '../components/Icon.astro';
import { SITE_URL } from '../config/site';

const title = "Contacto | Cita con psicóloga en Córdoba (presencial y online)";
const description = "Pide cita con María Ángeles Mata, psicóloga en Córdoba: consulta en Rodríguez Sánchez 9 o terapia online. Teléfono, email y formulario. Respuesta en menos de 24 h.";
const keywords = "cita psicólogo córdoba, contacto psicóloga, consulta psicología córdoba, terapia online cita, psicóloga rodríguez sánchez";

const SITE = SITE_URL;

const breadcrumbData = [
  { name: "Inicio", url: `${SITE}/` },
  { name: "Contacto", url: `${SITE}/contacto/` }
];

const contactPageData = {
  name: title,
  description,
  url: `${SITE}/contacto/`
};
---

<Layout {title} {description} {keywords} canonical="/contacto/">
  <Schema slot="schema" type="breadcrumbs" data={breadcrumbData} />
  <Schema slot="schema" type="webpage" data={contactPageData} />
  <Header activePage="Contacto" />
  
  <main id="main-content">
    
    <!-- Hero -->
    <section class="section bg-alabaster relative overflow-hidden" aria-labelledby="contact-heading">
      <div class="bg-aurora"></div>
      
      <div class="container-editorial relative z-10">
        <PageHeader
          label="Contacto"
          title="Dar el primer paso es lo más"
          highlight="difícil"
          description="Si estás buscando psicóloga en Córdoba o prefieres empezar con terapia online, puedes escribirme por teléfono, email o formulario. Respondo personalmente en menos de 24 horas."
        />
      </div>
    </section>

    <!-- Contenido principal -->
    <section class="section bg-cream relative">
      <div class="container-editorial">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
          
          <!-- Columna Info -->
          <div class="lg:col-span-5" data-reveal>
            <ContactInfoCard />
          </div>

          <!-- Columna Formulario -->
          <div class="lg:col-span-7" data-reveal data-reveal-delay="100">
            <div class="bg-alabaster p-8 lg:p-12 border border-border-delicate relative">
              {/* Borde decorativo */}
              <div class="absolute top-0 left-0 w-full h-[2px] bg-gradient-to-r from-olive via-olive/50 to-transparent"></div>
              
              <div class="mb-10">
                <span class="text-label text-olive mb-6 block">Escríbeme</span>
                <h2 class="font-serif text-2xl sm:text-3xl lg:text-4xl text-ink">
                  Reserva tu primera consulta
                </h2>
                <p class="text-body-sm sm:text-body text-charcoal mt-4">
                  No tienes que tenerlo todo claro. Cuéntame qué te preocupa y vemos si la terapia presencial en Córdoba o la modalidad online encajan contigo.
                </p>
              </div>
              
              <form class="space-y-6" action="#" method="POST">
                <div class="grid sm:grid-cols-2 gap-6">
                  <div class="group">
                    <label for="nombre" class="block text-label text-charcoal mb-3 group-focus-within:text-olive transition-colors">
                      Tu nombre <span class="text-olive">*</span>
                    </label>
                    <input 
                      type="text" 
                      id="nombre" 
                      name="nombre" 
                      placeholder="Cómo te llamo" 
                      class="w-full px-4 py-4 bg-cream border border-border-delicate text-ink focus:outline-none focus:border-olive focus:bg-alabaster transition-all duration-300 placeholder:text-charcoal/50"
                      required 
                    />
                  </div>
                  <div class="group">
                    <label for="telefono" class="block text-label text-charcoal mb-3 group-focus-within:text-olive transition-colors">
                      Teléfono
                    </label>
                    <input 
                      type="tel" 
                      id="telefono" 
                      name="telefono" 
                      placeholder="Si prefieres que te llame" 
                      class="w-full px-4 py-4 bg-cream border border-border-delicate text-ink focus:outline-none focus:border-olive focus:bg-alabaster transition-all duration-300 placeholder:text-charcoal/50"
                    />
                  </div>
                </div>
                
                <div class="group">
                  <label for="email" class="block text-label text-charcoal mb-3 group-focus-within:text-olive transition-colors">
                    Email <span class="text-olive">*</span>
                  </label>
                  <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    placeholder="tu@email.com" 
                    class="w-full px-4 py-4 bg-cream border border-border-delicate text-ink focus:outline-none focus:border-olive focus:bg-alabaster transition-all duration-300 placeholder:text-charcoal/50"
                    required 
                  />
                </div>
                
                <div class="group">
                  <label for="servicio" class="block text-label text-charcoal mb-3 group-focus-within:text-olive transition-colors">
                    ¿Qué te preocupa?
                  </label>
                  <div class="relative">
                    <select 
                      id="servicio" 
                      name="servicio"
                      class="w-full px-4 py-4 bg-cream border border-border-delicate text-ink focus:outline-none focus:border-olive focus:bg-alabaster transition-all duration-300 appearance-none cursor-pointer pr-12"
                    >
                      <option value="">Elige lo que más se acerque</option>
                      <option value="individual">Me siento mal y no sé por qué</option>
                      <option value="pareja">Problemas con mi pareja</option>
                      <option value="familiar">Conflictos familiares</option>
                      <option value="evaluacion">Problemas de memoria o atención</option>
                      <option value="cognitiva">Estimulación para persona mayor</option>
                      <option value="otro">Otro / No estoy seguro</option>
                    </select>
                    <Icon name="chevronDown" class="absolute right-4 top-1/2 -translate-y-1/2 w-5 h-5 text-charcoal pointer-events-none" />
                  </div>
                </div>
                
                <div class="group">
                  <label for="mensaje" class="block text-label text-charcoal mb-3 group-focus-within:text-olive transition-colors">
                    Tu mensaje <span class="text-olive">*</span>
                  </label>
                  <textarea 
                    id="mensaje" 
                    name="mensaje" 
                    placeholder="Escribe lo que necesites. No hay forma correcta de empezar..." 
                    rows="5" 
                    class="w-full px-4 py-4 bg-cream border border-border-delicate text-ink focus:outline-none focus:border-olive focus:bg-alabaster resize-none transition-all duration-300 placeholder:text-charcoal/40"
                    required
                  ></textarea>
                </div>
                
                <div class="pt-4 flex flex-col sm:flex-row items-start sm:items-center gap-6">
                  <button type="submit" class="btn btn-sage w-full sm:w-auto group">
                    <span>Enviar mensaje</span>
                    <Icon name="send" class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" />
                  </button>
                  <p class="text-label-sm text-charcoal">
                    Te respondo en menos de 24h. <a href="/privacidad" class="text-olive hover:underline underline-offset-2">Privacidad garantizada</a>.
                  </p>
                </div>
              </form>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Teléfono -->
    <CTASection
      label="Si prefieres hablar"
      title="A veces es más fácil"
      highlight="llamar"
      description="No pasa nada si no sabes qué decir. Solo di 'hola' y ya empezamos. Estoy aquí para escucharte."
      primaryAction={{ text: "697 733 060", href: "tel:+34697733060", icon: false }}
      variant="dark"
    />

  </main>
  
  <Footer />
</Layout>
