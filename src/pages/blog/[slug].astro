---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Schema from '../../components/Schema.astro';
import CTASection from '../../components/CTASection.astro';
import { blogPosts, getPostBySlug, blogPostsList } from '../../data/blog';
import { Image } from 'astro:assets';

export function getStaticPaths() {
  return Object.keys(blogPosts).map(slug => ({ params: { slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect('/404');
}

const title = `${post.title} | María Ángeles Mata`;
const canonicalUrl = `https://psicologia-mata.es/blog/${slug}`;

// Parse date
function parseDate(dateStr: string): string {
  const months: Record<string, string> = {
    'Enero': '01', 'Febrero': '02', 'Marzo': '03', 'Abril': '04',
    'Mayo': '05', 'Junio': '06', 'Julio': '07', 'Agosto': '08',
    'Septiembre': '09', 'Octubre': '10', 'Noviembre': '11', 'Diciembre': '12'
  };
  const parts = dateStr.split(' ');
  if (parts.length === 3) {
    const day = parts[0].padStart(2, '0');
    const month = months[parts[1]] || '01';
    const year = parts[2];
    return `${year}-${month}-${day}`;
  }
  return new Date().toISOString().split('T')[0];
}

const datePublished = parseDate(post.date);

// Get prev/next posts
const currentIndex = blogPostsList.findIndex(p => p.slug === slug);
const prevPost = currentIndex < blogPostsList.length - 1 ? blogPostsList[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? blogPostsList[currentIndex - 1] : null;

// Related posts (same category or random)
const relatedPosts = blogPostsList
  .filter(p => p.slug !== slug && p.category === post.category)
  .slice(0, 2);

const articleData = {
  headline: post.title,
  description: post.excerpt,
  image: post.image.src,
  datePublished: datePublished,
  dateModified: datePublished,
  author: {
    name: "María Ángeles Mata",
    url: "https://psicologia-mata.es"
  },
  publisher: {
    name: "María Ángeles Mata - Psicóloga",
    logo: "https://psicologia-mata.es/favicon.avif"
  },
  url: canonicalUrl
};

const breadcrumbData = [
  { name: "Inicio", url: "https://psicologia-mata.es/" },
  { name: "Blog", url: "https://psicologia-mata.es/blog" },
  { name: post.title, url: canonicalUrl }
];

// Share URLs
const shareUrls = {
  twitter: `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(canonicalUrl)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonicalUrl)}`,
  linkedin: `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonicalUrl)}`,
  whatsapp: `https://wa.me/?text=${encodeURIComponent(`${post.title} ${canonicalUrl}`)}`
};
---

<Layout 
  {title} 
  description={post.excerpt}
  type="article"
  image={post.image.src}
  canonical={`/blog/${slug}`}
  publishedTime={datePublished}
>
  <Schema slot="schema" type="article" data={articleData} />
  <Schema slot="schema" type="breadcrumbs" data={breadcrumbData} />
  
  <Header activePage="Blog" />
  
  <main id="main-content">
    
    <!-- Progress Bar -->
    <div id="reading-progress" class="fixed top-0 left-0 w-full h-[2px] z-[100] bg-transparent">
      <div class="h-full bg-terracotta origin-left scale-x-0 transition-transform duration-100" id="progress-bar"></div>
    </div>
    
    <!-- Hero Section - Editorial Style -->
    <section class="relative min-h-[70vh] sm:min-h-[80vh] lg:min-h-[85vh] flex flex-col justify-end bg-ink overflow-hidden" aria-labelledby="article-heading">
      
      <!-- Background Image with Overlay -->
      <div class="absolute inset-0">
        <Image 
          src={post.image} 
          alt="" 
          class="w-full h-full object-cover opacity-40 scale-105"
          aria-hidden="true"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/80 to-ink/30"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-ink/60 via-transparent to-ink/60"></div>
      </div>
      
      <!-- Decorative Elements -->
      <div class="absolute top-16 sm:top-20 right-6 sm:right-10 lg:right-20 text-right hidden md:block" data-reveal="right">
        <span class="font-serif text-[4rem] sm:text-[6rem] lg:text-[8rem] leading-none text-alabaster/5 font-light select-none">
          {post.dateShort.split(' ')[0]}
        </span>
        <span class="block font-sans text-label text-alabaster/20 mt-2 text-[0.625rem] sm:text-xs">{post.dateShort.split(' ')[1]}</span>
      </div>
      
      <!-- Content -->
      <div class="container-editorial relative z-10 pb-12 sm:pb-16 lg:pb-24">
        
        <!-- Breadcrumbs -->
        <nav class="mb-6 sm:mb-8" aria-label="Migas de pan" data-reveal>
          <ol class="flex items-center gap-2 sm:gap-3 text-[0.625rem] sm:text-xs text-alabaster/50 flex-wrap">
            <li><a href="/" class="hover:text-alabaster transition-colors duration-300">Inicio</a></li>
            <li class="text-alabaster/20">/</li>
            <li><a href="/blog" class="hover:text-alabaster transition-colors duration-300">Blog</a></li>
            <li class="text-alabaster/20">/</li>
            <li class="text-terracotta-light">{post.category}</li>
          </ol>
        </nav>
        
        <!-- Category & Meta -->
        <div class="flex flex-wrap items-center gap-3 sm:gap-6 mb-6 sm:mb-8" data-reveal data-reveal-delay="100">
          <span class="px-3 sm:px-4 py-1.5 sm:py-2 bg-terracotta/20 text-terracotta-light text-label-xs sm:text-label-sm rounded-full">
            {post.category}
          </span>
          <div class="flex items-center gap-2 sm:gap-4 text-label-xs sm:text-label-sm text-alabaster/60">
            <span class="flex items-center gap-1.5 sm:gap-2">
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
              </svg>
              {post.date}
            </span>
            <span class="w-1 h-1 rounded-full bg-alabaster/30"></span>
            <span class="flex items-center gap-1.5 sm:gap-2">
              <svg class="w-3.5 h-3.5 sm:w-4 sm:h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {post.readTime} de lectura
            </span>
          </div>
        </div>
        
        <!-- Title -->
        <div class="max-w-4xl" data-reveal data-reveal-delay="200">
          <h1 id="article-heading" class="font-serif text-[clamp(2rem,8vw,5rem)] text-alabaster leading-[1.05] sm:leading-[1.02] mb-6 sm:mb-8">
            {post.title}
          </h1>
          
          <!-- Excerpt -->
          <p class="font-sans text-base sm:text-lg lg:text-xl text-alabaster/70 font-light leading-relaxed max-w-2xl border-l-2 border-terracotta-light pl-4 sm:pl-6">
            {post.excerpt}
          </p>
        </div>
        
        <!-- Scroll Indicator -->
        <div class="absolute bottom-6 sm:bottom-8 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-2 text-alabaster/40 animate-bounce">
          <span class="text-label-xs uppercase tracking-widest">Leer</span>
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </div>
      </div>
    </section>
    
    <!-- Article Content - Editorial Layout -->
    <article class="bg-alabaster relative">
      
      <!-- Sticky Sidebar (Desktop) -->
      <div class="hidden xl:block fixed left-4 2xl:left-8 top-1/2 -translate-y-1/2 z-40" id="article-sidebar">
        <div class="flex flex-col items-center gap-4 2xl:gap-6">
          <!-- Share Buttons -->
          <div class="flex flex-col gap-2 2xl:gap-3">
            <span class="text-label-xs text-ink uppercase tracking-wider mb-2 writing-mode-vertical text-[0.625rem]">Compartir</span>
            <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" class="w-9 h-9 2xl:w-10 2xl:h-10 rounded-full border border-border-delicate flex items-center justify-center text-ink hover:bg-ink hover:text-alabaster hover:border-ink transition-all duration-300" aria-label="Compartir en Twitter">
              <svg class="w-3.5 h-3.5 2xl:w-4 2xl:h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 2xl:w-10 2xl:h-10 rounded-full border border-border-delicate flex items-center justify-center text-ink hover:bg-[#1877F2] hover:text-white hover:border-[#1877F2] transition-all duration-300" aria-label="Compartir en Facebook">
              <svg class="w-3.5 h-3.5 2xl:w-4 2xl:h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href={shareUrls.whatsapp} target="_blank" rel="noopener noreferrer" class="w-9 h-9 2xl:w-10 2xl:h-10 rounded-full border border-border-delicate flex items-center justify-center text-ink hover:bg-[#25D366] hover:text-white hover:border-[#25D366] transition-all duration-300" aria-label="Compartir en WhatsApp">
              <svg class="w-3.5 h-3.5 2xl:w-4 2xl:h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Main Content -->
      <div class="container-editorial py-12 sm:py-16 lg:py-24">
        <div class="max-w-3xl mx-auto px-4 sm:px-0">
          
          <!-- Article Body with Custom Typography -->
          <div 
            id="article-content"
            class="article-body"
            set:html={post.content}
          />
          
          <!-- Tags -->
          <div class="mt-16 pt-10 border-t border-border-delicate">
            <div class="flex flex-wrap items-center gap-3">
              <span class="text-label-sm text-ink">Etiquetas:</span>
              <span class="px-4 py-2 bg-cream border border-border-delicate text-label-sm text-ink hover:border-olive hover:text-olive transition-colors cursor-pointer">
                {post.category}
              </span>
              <span class="px-4 py-2 bg-cream border border-border-delicate text-label-sm text-ink hover:border-olive hover:text-olive transition-colors cursor-pointer">
                Psicología
              </span>
              <span class="px-4 py-2 bg-cream border border-border-delicate text-label-sm text-ink hover:border-olive hover:text-olive transition-colors cursor-pointer">
                Bienestar
              </span>
            </div>
          </div>
          
          <!-- Author Box -->
          <footer class="mt-16 p-8 lg:p-10 bg-cream border border-border-delicate relative overflow-hidden">
            <!-- Decorative -->
            <div class="absolute top-0 right-0 w-32 h-32 bg-olive/5 rounded-bl-full"></div>
            
            <div class="relative flex flex-col sm:flex-row items-start sm:items-center gap-6">
              <div class="w-20 h-20 rounded-full bg-olive flex items-center justify-center shrink-0">
                <span class="font-serif text-3xl text-alabaster">M</span>
              </div>
              <div class="flex-1">
                <p class="font-serif text-2xl text-ink mb-2">María Ángeles Mata</p>
                <p class="font-sans text-body-sm text-charcoal mb-4">Psicóloga General Sanitaria · Colegiada nº AN 12177 · Más de 15 años acompañando a personas en su proceso de crecimiento personal</p>
                <div class="flex items-center gap-4">
                  <a href="/contact" class="text-label text-olive hover:text-ink transition-colors">Contactar</a>
                  <span class="text-charcoal">·</span>
                  <a href="/services" class="text-label text-olive hover:text-ink transition-colors">Servicios</a>
                </div>
              </div>
            </div>
          </footer>
          
          <!-- Mobile Share -->
          <div class="mt-10 sm:mt-12 xl:hidden">
            <p class="text-label-xs sm:text-label-sm text-ink mb-3 sm:mb-4 text-center">Compartir artículo</p>
            <div class="flex justify-center gap-3 sm:gap-4">
              <a href={shareUrls.twitter} target="_blank" rel="noopener noreferrer" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full border border-border-delicate flex items-center justify-center text-ink hover:bg-ink hover:text-alabaster transition-all">
                <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href={shareUrls.facebook} target="_blank" rel="noopener noreferrer" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full border border-border-delicate flex items-center justify-center text-ink hover:bg-[#1877F2] hover:text-white transition-all">
                <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href={shareUrls.whatsapp} target="_blank" rel="noopener noreferrer" class="w-10 h-10 sm:w-12 sm:h-12 rounded-full border border-border-delicate flex items-center justify-center text-ink hover:bg-[#25D366] hover:text-white transition-all">
                <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
              </a>
            </div>
          </div>
          
        </div>
      </div>
    </article>
    
    <!-- Post Navigation -->
    <nav class="bg-cream border-t border-border-delicate" aria-label="Navegación entre artículos">
      <div class="container-editorial">
        <div class="grid md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-border-delicate">
          
          {prevPost ? (
            <a href={`/blog/${prevPost.slug}`} class="group p-8 lg:p-12 hover:bg-alabaster transition-colors duration-500">
              <div class="flex items-start gap-4">
                <div class="w-12 h-12 rounded-full border border-border-strong flex items-center justify-center text-ink group-hover:bg-olive group-hover:border-olive group-hover:text-alabaster transition-all duration-300 shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
                  </svg>
                </div>
                <div>
                  <span class="text-label-xs text-ink uppercase tracking-wider block mb-2">Artículo anterior</span>
                  <h3 class="font-serif text-xl lg:text-2xl text-ink group-hover:text-olive transition-colors duration-300 leading-tight">
                    {prevPost.title}
                  </h3>
                  <span class="text-label-sm text-charcoal mt-2 block">{prevPost.date}</span>
                </div>
              </div>
            </a>
          ) : (
            <div class="p-8 lg:p-12 opacity-50">
              <span class="text-label-xs text-ink uppercase tracking-wider">No hay artículo anterior</span>
            </div>
          )}
          
          {nextPost ? (
            <a href={`/blog/${nextPost.slug}`} class="group p-8 lg:p-12 hover:bg-alabaster transition-colors duration-500 text-right">
              <div class="flex items-start gap-4 flex-row-reverse">
                <div class="w-12 h-12 rounded-full border border-border-strong flex items-center justify-center text-ink group-hover:bg-olive group-hover:border-olive group-hover:text-alabaster transition-all duration-300 shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                  </svg>
                </div>
                <div>
                  <span class="text-label-xs text-ink uppercase tracking-wider block mb-2">Artículo siguiente</span>
                  <h3 class="font-serif text-xl lg:text-2xl text-ink group-hover:text-olive transition-colors duration-300 leading-tight">
                    {nextPost.title}
                  </h3>
                  <span class="text-label-sm text-charcoal mt-2 block">{nextPost.date}</span>
                </div>
              </div>
            </a>
          ) : (
            <div class="p-8 lg:p-12 opacity-50 text-right">
              <span class="text-label-xs text-ink uppercase tracking-wider">No hay artículo siguiente</span>
            </div>
          )}
          
        </div>
      </div>
    </nav>
    
    <!-- Related Articles -->
    {relatedPosts.length > 0 && (
      <section class="section bg-alabaster" aria-labelledby="related-heading">
        <div class="container-editorial">
          <div class="max-w-4xl mx-auto">
            <h2 id="related-heading" class="font-serif text-3xl lg:text-4xl text-ink mb-12 text-center" data-reveal>
              Artículos <em class="text-olive italic">relacionados</em>
            </h2>
            
            <div class="grid md:grid-cols-2 gap-8">
              {relatedPosts.map((relatedPost, index) => (
                <article class="group" data-reveal data-reveal-delay={index * 100}>
                  <a href={`/blog/${relatedPost.slug}`} class="block">
                    <div class="relative aspect-[16/10] overflow-hidden mb-6">
                      <Image 
                        src={relatedPost.image} 
                        alt={relatedPost.title}
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        loading="lazy"
                      />
                      <div class="absolute inset-0 bg-ink/0 group-hover:bg-ink/10 transition-colors duration-500"></div>
                    </div>
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-label-xs text-olive">{relatedPost.category}</span>
                      <span class="w-1 h-1 rounded-full bg-taupe"></span>
                      <span class="text-label-xs text-charcoal">{relatedPost.readTime}</span>
                    </div>
                    <h3 class="font-serif text-xl text-ink group-hover:text-olive transition-colors duration-300 leading-tight">
                      {relatedPost.title}
                    </h3>
                  </a>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>
    )}
    
    <!-- Back to Blog -->
    <section class="section-sm bg-cream border-t border-border-delicate">
      <div class="container-editorial text-center">
