<script>
  // Reading Progress
  (function() {
    const progressBar = document.getElementById('progress-bar');
    const articleContent = document.getElementById('article-content');
    
    if (!progressBar || !articleContent) return;
    
    let ticking = false;
    
    function updateProgress() {
      if (!articleContent || !progressBar) return;
      
      const articleRect = articleContent.getBoundingClientRect();
      const articleTop = articleRect.top + window.scrollY;
      const articleHeight = articleRect.height;
      const windowHeight = window.innerHeight;
      
      const scrollProgress = Math.max(0, Math.min(1, 
        (window.scrollY - articleTop + windowHeight / 2) / articleHeight
      ));
      
      progressBar.style.transform = `scaleX(${scrollProgress})`;
      ticking = false;
    }
    
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(updateProgress);
        ticking = true;
      }
    }
    
    window.addEventListener('scroll', onScroll, { passive: true });
    updateProgress();
  })();
  
  // Show/hide sidebar on scroll
  (function() {
    const sidebar = document.getElementById('article-sidebar');
    if (!sidebar) return;
    
    const articleContent = document.getElementById('article-content');
    if (!articleContent) return;
    
    let ticking = false;
    
    function toggleSidebar() {
      if (!articleContent || !sidebar) return;
      
      const articleRect = articleContent.getBoundingClientRect();
      const isVisible = articleRect.top < window.innerHeight / 2 && articleRect.bottom > window.innerHeight / 2;
      
      sidebar.style.opacity = isVisible ? '1' : '0';
      sidebar.style.pointerEvents = isVisible ? 'auto' : 'none';
      ticking = false;
    }
    
    function onScroll() {
      if (!ticking) {
        requestAnimationFrame(toggleSidebar);
        ticking = true;
      }
    }
    
    window.addEventListener('scroll', onScroll, { passive: true });
    toggleSidebar();
  })();
</script>
