---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHeader from '../../components/PageHeader.astro';
import CTASection from '../../components/CTASection.astro';
import { blogPostsList } from '../../data/blog';

const title = "Blog de Psicología | María Ángeles Mata";
const description = "Artículos sobre psicología, salud mental, terapia y crecimiento personal. Reflexiones de una psicóloga sanitaria con 15+ años de experiencia.";

const featuredPost = blogPostsList[0];
const recentPosts = blogPostsList.slice(1);

const categories = [...new Set(blogPostsList.map(post => post.category))];
---

<Layout {title} {description}>
  <Header activePage="Blog" />
  
  <main id="main-content">
    
    <!-- Hero -->
    <section class="section bg-alabaster relative overflow-hidden" aria-labelledby="blog-heading">
      <div class="bg-aurora"></div>
      
      <div class="container-editorial relative z-10">
        <PageHeader
          label="Blog"
          title="Reflexiones para el"
          highlight="día a día"
          description="Pequeñas ideas, consejos prácticos y reflexiones sobre lo que significa cuidar nuestra salud mental en el mundo real."
        >
          {/* Categorías */}
          <div class="flex flex-wrap gap-3 mt-16">
            {categories.map((category) => (
              <span class="px-4 py-2 bg-cream border border-border-delicate text-label-sm text-ink">
                {category}
              </span>
            ))}
          </div>
        </PageHeader>
      </div>
    </section>

    <!-- Artículo Destacado -->
    <section class="section bg-cream relative" aria-labelledby="featured-heading">
      <div class="container-editorial">
        
        <div class="mb-12" data-reveal>
          <span class="label-section">Artículo destacado</span>
        </div>

        <article class="group" data-reveal data-reveal-delay="100">
          <a href={`/blog/${featuredPost.slug}`} class="block">
            <div class="grid lg:grid-cols-2 gap-8 lg:gap-16 items-center">
              
              {/* Imagen */}
              <div class="relative">
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img 
                    src={featuredPost.image} 
                    alt={featuredPost.title}
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                    width="800"
                    height="600"
                    loading="eager"
                  />
                  <div class="absolute inset-0 bg-gradient-to-tr from-ink/20 via-transparent to-transparent"></div>
                </div>
                
                <div class="absolute top-4 left-4">
                  <span class="px-4 py-2 bg-alabaster/95 backdrop-blur-sm text-label text-olive">
                    {featuredPost.category}
                  </span>
                </div>
              </div>
              
              {/* Contenido */}
              <div>
                <div class="flex items-center gap-4 mb-6">
                  <span class="text-label-sm text-charcoal">{featuredPost.date}</span>
                  <span class="w-8 h-[1px] bg-border-strong"></span>
                  <span class="text-label-sm text-olive">{featuredPost.readTime} de lectura</span>
                </div>

                <h2 id="featured-heading" class="font-serif text-3xl lg:text-4xl text-ink mb-6 group-hover:text-olive transition-colors duration-500 leading-tight">
                  {featuredPost.title}
                </h2>

                <p class="text-body text-charcoal mb-8 leading-relaxed">
                  {featuredPost.excerpt}
                </p>

                <span class="inline-flex items-center gap-3 text-label text-ink group-hover:text-olive transition-colors duration-300">
                  <span>Leer artículo</span>
                  <span class="w-10 h-10 rounded-full border border-current flex items-center justify-center group-hover:bg-olive group-hover:border-olive group-hover:text-alabaster transition-all duration-500">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.75L21 12m0 0l-3.75 3.25M21 12H3" />
                    </svg>
                  </span>
                </span>
              </div>
            </div>
          </a>
        </article>

      </div>
    </section>

    <!-- Artículos Recientes -->
    <section class="section bg-alabaster relative" aria-labelledby="recent-heading">
      <div class="container-editorial">
        
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16 border-b border-border-strong pb-8">
          <div data-reveal>
            <span class="label-section mb-6">Más artículos</span>
            <h2 id="recent-heading" class="title-section">
              Para seguir <em class="text-olive italic">aprendiendo</em>
            </h2>
          </div>
          <div data-reveal data-reveal-delay="100">
            <p class="text-body-sm text-charcoal max-w-sm">
              Pequeñas dosis de psicología para aplicar en tu día a día.
            </p>
          </div>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-12">
          {recentPosts.map((post, index) => (
            <article 
              class="group"
              data-reveal 
              data-reveal-delay={index * 100}
            >
              <a href={`/blog/${post.slug}`} class="block">
                {/* Imagen */}
                <div class="relative aspect-[4/3] overflow-hidden mb-6">
                  <img 
                    src={post.image} 
                    alt={post.title}
                    class="w-full h-full object-cover transition-all duration-700 group-hover:scale-105"
                    width="600"
                    height="450"
                    loading="lazy"
                  />
                  <div class="absolute inset-0 bg-olive/0 group-hover:bg-olive/10 transition-colors duration-500"></div>
                </div>
                
                {/* Meta */}
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-label-sm text-olive">{post.category}</span>
                  <span class="w-1 h-1 rounded-full bg-taupe"></span>
                  <span class="text-label-sm text-charcoal">{post.date}</span>
                </div>
                
                {/* Título */}
                <h3 class="font-serif text-xl lg:text-2xl text-ink group-hover:text-olive transition-colors duration-500 mb-4 leading-tight">
                  {post.title}
                </h3>
                
                {/* Extracto */}
                <p class="text-body-sm text-charcoal line-clamp-2 mb-6">
                  {post.excerpt}
                </p>
                
                {/* Link */}
                <div class="flex items-center gap-2 text-label-sm text-ink group-hover:text-olive transition-colors duration-300">
                  <span>Leer</span>
                  <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.75L21 12m0 0l-3.75 3.25M21 12H3" />
                  </svg>
                </div>
              </a>
            </article>
          ))}
        </div>

      </div>
    </section>

    <!-- CTA Final -->
    <CTASection
      label="¿Necesitas hablar?"
      title="Los artículos ayudan,"
      highlight="pero a veces necesitamos más"
      description="Si sientes que lo que lees no es suficiente, quizás es momento de dar el paso. Estoy aquí para escucharte sin juzgarte."
      primaryAction={{ text: "Hablamos", href: "/contact" }}
      variant="dark"
    />

  </main>
  
  <Footer />
</Layout>
